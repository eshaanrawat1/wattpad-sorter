{
  "manifest_version": 3,
  "name": "Wattpad Views Sorter",
  "version": "0.1.0",
  "description": "Add sorting by views to Wattpad story cards.",
    
  "icons": {
    "16": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  },

  "content_scripts": [
    {
      "matches": ["https://www.wattpad.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
